# Zhihu MCP Configuration

# Directory to store auth state (cookies). Default: ~/.zhihu-mcp
# ZHIHU_STATE_DIR=~/.zhihu-mcp

# Run browser in headless mode. Default: true
# Set to "false" for interactive login (recommended for first-time setup)
ZHIHU_HEADLESS=false

# Delay between requests in seconds. Default: 2.0
# ZHIHU_REQUEST_DELAY=2.0
